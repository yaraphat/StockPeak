# Stock Peak — Environment Variables
# Copy to .env and fill in values before running.
#
# docker compose up --build -d

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by BOTH the Python SDK and the Claude Code CLI.
# Set one; the entrypoint maps it to the other automatically.
# Claude Code CLI uses ANTHROPIC_API_KEY. Python scripts use CLAUDE_API_KEY.
CLAUDE_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...   # alternative name, same key

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Public URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Optional: External Database ───────────────────────────────────────────────
# Leave blank to use the bundled PostgreSQL inside the container.
# Set this to use an external DB (e.g. Neon, Supabase, Railway).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Internal DB password (only used when DATABASE_URL is not set above)
# STOCKPEAK_DB_PASSWORD=stockpeak

# ── Optional: Google OAuth ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Optional: Telegram Notifications ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
# OWNER_TELEGRAM_ID=

# ── Optional: Email (Resend) ──────────────────────────────────────────────────
# RESEND_API_KEY=

# ── Optional: Pipeline tuning ────────────────────────────────────────────────
# Enable multi-agent bull/bear debate (slower, more tokens)
# MULTI_AGENT=0

# Claude model to use for pick generation
# CLAUDE_MODEL=claude-sonnet-4-6

# Minimum resolved picks before feedback compiler runs
# FEEDBACK_MIN_SAMPLE=30
